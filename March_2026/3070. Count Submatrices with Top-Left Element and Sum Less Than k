class Solution {
public:
    int countSubmatrices(vector<vector<int>>& grid, int k) {
        int m = grid.size();
        int n= grid[0].size();
        int count=0;
        vector<vector<int>>sum(m,vector<int>(n,0));
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(i==0 && j==0){
                    sum[i][j]= grid[i][j];
                    if(sum[i][j]<=k) count++;
                }
                else if((i==0)){
                    sum[i][j]= sum[i][j-1] + grid[i][j];
                    if(sum[i][j]<=k) count++;
                }
                else if((j==0)){
                    sum[i][j]= sum[i-1][j] + grid[i][j];
                    if(sum[i][j]<=k) count++;
                }
                else{
                    sum[i][j]= sum[i-1][j]+ sum[i][j-1]+ 
                               grid[i][j]- sum[i-1][j-1];

                    if(sum[i][j]<=k) count++;



                }
                
            }
        }

        return count;
        
    }
};