class Solution {
public:
    int maxProductPath(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();
        long long MOD = 1e9 + 7;
        
        // Dono min aur max track karne padenge
        vector<vector<long long>> max_dp(m, vector<long long>(n, 0));
        vector<vector<long long>> min_dp(m, vector<long long>(n, 0));
        
        max_dp[0][0] = grid[0][0];
        min_dp[0][0] = grid[0][0];
        
        for(int i = 0; i < m; i++) {
            for(int j = 0; j < n; j++) {
                if(i == 0 && j == 0) continue; 
                
                long long cur = grid[i][j];
                
                long long temp_max = -4e18; 
                long long temp_min = 4e18;  
                
                if(i > 0) {
                    temp_max = max({temp_max, max_dp[i-1][j] * cur, 
                    min_dp[i-1][j] * cur});
                    temp_min = min({temp_min, max_dp[i-1][j] * cur, 
                    min_dp[i-1][j] * cur});
                }
                
                if(j > 0) {
                    temp_max = max({temp_max, max_dp[i][j-1] * cur, 
                    min_dp[i][j-1] * cur});
                    temp_min = min({temp_min, max_dp[i][j-1] * cur, 
                    min_dp[i][j-1] * cur});
                }
                
                max_dp[i][j] = temp_max;
                min_dp[i][j] = temp_min;
            }
        }
        
        if(max_dp[m-1][n-1] < 0) return -1;
        
       
        return max_dp[m-1][n-1] % MOD;
    }
};