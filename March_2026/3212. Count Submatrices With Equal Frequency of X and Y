class Solution {
public:
    int numberOfSubmatrices(vector<vector<char>>& grid) {
        int m= grid.size();
        int n= grid[0].size();
        vector<vector<pair<int,int>>>freq(m,vector<pair<int,int>>(n,{0,0}));
        int count=0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){

                if(i==0 && j==0){
                    if(grid[i][j]=='X') freq[i][j].first++;
                    if(grid[i][j]=='Y') freq[i][j].second++;
                  
                }
                else if(i==0){
                     if(grid[i][j]=='X'){
                        freq[i][j].first= freq[i][j-1].first +1;
                        freq[i][j].second= freq[i][j-1].second;
                     }
                     if(grid[i][j]=='Y'){
                        freq[i][j].second= freq[i][j-1].second +1;
                        freq[i][j].first= freq[i][j-1].first;
                     }
                     if(grid[i][j]=='.'){
                        freq[i][j].second= freq[i][j-1].second ;
                        freq[i][j].first= freq[i][j-1].first;
                     }
                    
                    if((freq[i][j].first==freq[i][j].second) && 
                    (freq[i][j].first!=0)) count++;
                     
                }
                else if((j==0)){

                    if(grid[i][j]=='X'){
                        freq[i][j].first= freq[i-1][j].first +1;
                        freq[i][j].second= freq[i-1][j].second;
                     }
                     if(grid[i][j]=='Y'){
                        freq[i][j].second= freq[i-1][j].second +1;
                        freq[i][j].first= freq[i-1][j].first;
                     }
                     if(grid[i][j]=='.'){
                        freq[i][j].second= freq[i-1][j].second ;
                        freq[i][j].first= freq[i-1][j].first;
                     }
                    
                    if((freq[i][j].first==freq[i][j].second) && 
                    (freq[i][j].first!=0)) count++;
                    
                }
                else{
                    if(grid[i][j]=='X'){
                        freq[i][j].first= freq[i-1][j].first + 
                        freq[i][j-1].first +1 - freq[i-1][j-1].first;
                        freq[i][j].second= freq[i-1][j].second + 
                        freq[i][j-1].second - freq[i-1][j-1].second;
                     }
                     if(grid[i][j]=='Y'){
                        freq[i][j].first= freq[i-1][j].first + 
                        freq[i][j-1].first  - freq[i-1][j-1].first;
                        freq[i][j].second= freq[i-1][j].second + 
                        freq[i][j-1].second - freq[i-1][j-1].second +1;
                     }
                     if(grid[i][j]=='.'){
                        freq[i][j].first= freq[i-1][j].first + 
                        freq[i][j-1].first  - freq[i-1][j-1].first;
                        freq[i][j].second= freq[i-1][j].second + 
                        freq[i][j-1].second - freq[i-1][j-1].second ;
                     }
                    
                    if((freq[i][j].first==freq[i][j].second) && 
                    (freq[i][j].first!=0)) count++;
                    

                    



                }
                
            }
        }

        return count;
        
    }
};