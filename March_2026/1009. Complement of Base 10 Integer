class Solution {
public:
    int bitwiseComplement(int n) {
        int mask=0;
        int a=n;
        if(n==0) return 1;
        while(a!=0){
            a=a>>1;
            mask=mask<<1;
            mask=mask | 1;
            
        }
        n= ~n;
        n= n&mask;
        

        return n;
    }
    
};