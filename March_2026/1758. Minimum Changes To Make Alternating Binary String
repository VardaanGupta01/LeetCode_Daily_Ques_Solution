class Solution {
public:
    int minOperations(string s) {
        
        int n= s.size();
        string str= "";
        int num01=0;
        for(int i=0;i<n;i++){
            if(i%2==0){
                str+="0";
                if(str[i]!=s[i]){
                    num01++;
                }
            }
            else{
                str+="1";
                if(str[i]!=s[i]){
                    num01++;
                }
            }
        }

        return min(num01, n-num01);
        
    }
};