class Solution {
public:
    int numSpecial(vector<vector<int>>& mat) {
        int m= mat.size();
        int n= mat[0].size();
        vector<int>rows_freq(m ,0);
        vector<int>cols_freq(n,0);
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(mat[i][j]==1){
                    rows_freq[i]++;
                    cols_freq[j]++;
                }
            }
        }

        int ans=0;
        for(int i=0;i<m;i++){
            if(rows_freq[i]==1){
            for(int j=0;j<n;j++){
                if((mat[i][j]==1) && (cols_freq[j]==1)){
                    ans++;
                }
            }
            }
        }

        return ans;
        
    }
};