class Solution {
public:
    void rotate(vector<vector<int>>& arr) {
        int rows= arr.size();
        int cols= arr[0].size();
        for(int i=0;i<rows;i++){
            for(int j=0;j<i;j++){
                swap(arr[i][j],arr[j][i]);
            }
        }
        for(int i=0;i<rows;i++){
            int temp=rows;
            for(int j=0;j<temp/2;j++){
                swap(arr[i][j],arr[i][cols-1-j]);
            }
        }
        
    }
};