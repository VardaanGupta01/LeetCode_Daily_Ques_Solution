class Robot {
public:

    vector<int>dy={0,1,0,-1};
    vector<int>dx={1,0,-1,0};
    int dir;
    int curr_x=0,curr_y=0;
    int width,height;
    int perimeter;
   


    Robot(int widt, int heigh) {
        width= widt;
        height= heigh;
        dir=0; 
        perimeter= 2 * (width - 1) + 2 * (height - 1);
    }
    
    void step(int num) {
        num= num%perimeter;
        if(num==0) num= perimeter; //very imp fix
        curr_x+=(dx[dir]*num);
        curr_y+=(dy[dir]*num);
        int temp;
        if(curr_x<0){
            temp= -1*curr_x;
            curr_x=0;
            dir= (dir+1)%4;
            step(temp);
        }
        else if(curr_x>=width){
            temp= curr_x-width+1;
            curr_x= width-1;
            dir= (dir+1)%4;
            step(temp);
        }
        else if(curr_y<0){
            temp= -1*curr_y;
            curr_y= 0;
            dir= (dir+1)%4;
            step(temp);
        }
        else if(curr_y>=height){
            temp= curr_y-height+1;
            curr_y= height-1;
            dir= (dir+1)%4;
            step(temp);
        }
        return;
        
    }
    
    vector<int> getPos() {
        return {curr_x,curr_y};

    }
    
    string getDir() {
        if(dir==0) return "East";
        else if(dir==1) return "North";
        else if(dir==2) return "West";
        else return "South";
        
    }
};

