class Solution {
public:
    bool judgeCircle(string moves) {

        int hor=0;
        int vert=0;
        for(int i=0;i<moves.size();i++){
            if(moves[i]=='R' ) hor++;
            else if(moves[i]=='L' ) hor--;
            else if(moves[i]=='U' ) vert++;
            else if(moves[i]=='D' ) vert--;
            

            
        }

        if(hor==0 && vert==0) return true;
            return false;
        
    }
};