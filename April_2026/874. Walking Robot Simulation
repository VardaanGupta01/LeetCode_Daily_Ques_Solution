class Solution {
public:
    int robotSim(vector<int>& commands, vector<vector<int>>& obstacles) {

        int curr_x=0;
        int curr_y=0;
        vector<int>dx={0,1,0,-1};
        vector<int>dy={1,0,-1,0};
        int dir=0;
        int eucmax=0;
        unordered_set<long long > s;
        for(int i=0;i<obstacles.size();i++){
            long long hash = (obstacles[i][0] + 30000LL) * 100000LL + (obstacles[i][1] + 30000LL);
            s.insert(hash);
        }
        for(int i=0;i<commands.size();i++){
            if(commands[i]==-2){
                dir= (dir+3)%4;
                
            }

            else if(commands[i]==-1){
                dir= (dir+1)%4;
                
            }

            else{

                if(dx[dir]!=0){
                    int tempx= curr_x + dx[dir]*commands[i];
                    while(curr_x!=tempx){
                        curr_x+=dx[dir];
                        long long curr_hash = (curr_x + 30000LL) * 100000LL + (curr_y + 30000LL);
                        if(s.find(curr_hash)!= s.end()){

                            curr_x-=dx[dir];
                            break;
                        }
                        eucmax= max(curr_x*curr_x + curr_y*curr_y, eucmax);
                    }
                    


                }
                else{
                    int tempy= curr_y + dy[dir]*commands[i];
                    while(curr_y!=tempy){
                        curr_y+=dy[dir];
                        long long curr_hash = (curr_x + 30000LL) * 100000LL + (curr_y + 30000LL);
                        if(s.find(curr_hash)!= s.end()){

                            curr_y-=dy[dir];
                            break;
                        }
                        eucmax= max(curr_x*curr_x + curr_y*curr_y, eucmax);
                    }
                }

                
                

            }
        }

        return eucmax;
        
    }
};