class Solution {
public:
    int maxWalls(vector<int>& robots, vector<int>& distance, vector<int>& walls) {
        int n = robots.size();
        
        vector<pair<int, int>> rd(n);
        for(int i = 0; i < n; i++) {
            rd[i] = {robots[i], distance[i]};
        }
        sort(rd.begin(), rd.end());
        
       
        sort(walls.begin(), walls.end());
        walls.erase(unique(walls.begin(), walls.end()), walls.end());
        
        int walls_at_robots = 0;
        vector<int> rem_walls; 
        
        for(int w : walls) {
            auto it = lower_bound(rd.begin(), rd.end(), make_pair(w, -1));
            if(it != rd.end() && it->first == w) {
                walls_at_robots++;
            } else {
                rem_walls.push_back(w);
            }
        }
        
        auto get_walls = [&](int i, int choice1, int choice2) {
            int L = rd[i].first;
            int R = rd[i+1].first;
            
            int p_right = (choice1 == 1) ? rd[i].first + rd[i].second : L - 1;
            int p_left = (choice2 == 0) ? rd[i+1].first - rd[i+1].second : R + 1;
            
            auto it_start = upper_bound(rem_walls.begin(), rem_walls.end(), L);
            auto it_end = lower_bound(rem_walls.begin(), rem_walls.end(), R);
            
            int count = 0;
            for(auto it = it_start; it != it_end; ++it) {
                int w = *it;
                
                if(w <= p_right || w >= p_left) {
                    count++;
                }
            }
            return count;
        };
        
        vector<vector<int>> dp(n, vector<int>(2, 0));
        
        int start_w = rd[0].first - rd[0].second;
        auto it0_start = lower_bound(rem_walls.begin(), rem_walls.end(), start_w);
        auto it0_end = lower_bound(rem_walls.begin(), rem_walls.end(), rd[0].first);
        dp[0][0] = std::distance(it0_start, it0_end); 
        dp[0][1] = 0; 
        
        for(int i = 1; i < n; i++) {
            int w_00 = get_walls(i-1, 0, 0); 
            int w_10 = get_walls(i-1, 1, 0); 
            int w_01 = get_walls(i-1, 0, 1); 
            int w_11 = get_walls(i-1, 1, 1); 
            
            dp[i][0] = max(dp[i-1][0] + w_00, dp[i-1][1] + w_10);
            
            dp[i][1] = max(dp[i-1][0] + w_01, dp[i-1][1] + w_11);
        }
        
        int end_w = rd[n-1].first + rd[n-1].second;
        auto itn_start = upper_bound(rem_walls.begin(), rem_walls.end(), rd[n-1].first);
        auto itn_end = upper_bound(rem_walls.begin(), rem_walls.end(), end_w);
        int count_right_last = std::distance(itn_start, itn_end);
        
        int best_combinations = max(dp[n-1][0], dp[n-1][1] + count_right_last);
        
        return best_combinations + walls_at_robots;
    }
};