class Solution {
public:
    int minimumDistance(vector<int>& nums) {
        int n= nums.size();
        vector<vector<int>>v(n+1);
        for(int i=0;i<n;i++){
            v[nums[i]].push_back(i);
        }
        int ans=-1;
        for(int i=1;i<=n;i++){
            int size= v[i].size();
            if(size<3) continue;
            else{

                int temp_sum= abs(v[i][0]-v[i][1])+abs(v[i][2]-v[i][1])+
                                abs(v[i][0]-v[i][2]);
                if(ans==-1) ans= temp_sum;
                else ans= min(ans, temp_sum);
                for(int j=0;j<size-2;j++){
                    temp_sum= abs(v[i][j]-v[i][j+1])+abs(v[i][j+2]-v[i][j+1])+
                                abs(v[i][j]-v[i][j+2]);
                    ans= min(ans, temp_sum);
                }
            }
        }

        return ans;

        
    }
};