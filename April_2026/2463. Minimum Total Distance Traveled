class Solution {
public:
    long long minimumTotalDistance(vector<int>& robot, vector<vector<int>>& factory) {
        sort(robot.begin(), robot.end());
        sort(factory.begin(), factory.end());

        vector<int> flat_factories;
        for (auto& f : factory) {
            for (int i = 0; i < f[1]; i++) {
                flat_factories.push_back(f[0]);
            }
        }

        int n = robot.size();
        int m = flat_factories.size();

        vector<vector<long long>> memo(n, vector<long long>(m, -1));

        return solve(0, 0, robot, flat_factories, memo);
    }

private:
    long long solve(int i, int j, const vector<int>& robot, const vector<int>& factories, vector<vector<long long>>& memo) {
        if (i == robot.size()) return 0; 
        
        if (j == factories.size()) return 1e16; 

        if (memo[i][j] != -1) return memo[i][j];

        long long skip = solve(i, j + 1, robot, factories, memo);

        long long take = abs(robot[i] - factories[j]) + solve(i + 1, j + 1, robot, factories, memo);

        return memo[i][j] = min(skip, take);
    }
};