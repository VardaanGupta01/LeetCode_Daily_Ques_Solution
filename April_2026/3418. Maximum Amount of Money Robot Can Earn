class Solution {
public:
    int maximumAmount(vector<vector<int>>& coins) {
        int m= coins.size();
        int n= coins[0].size();
        vector<vector<vector<int>>>dp(m,vector<vector<int>>(n,vector<int>(3,INT_MIN)));

        if(coins[0][0]>=0){
            dp[0][0][0]= coins[0][0];
        }
        else{
            dp[0][0][0]= coins[0][0];
            dp[0][0][1]=0;
        }

        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(i>0){
                    if(coins[i][j]>=0){
                        if(dp[i-1][j][0]!=INT_MIN){
                            dp[i][j][0]= coins[i][j]+dp[i-1][j][0];
                        }
                        if(dp[i-1][j][1]!=INT_MIN){
                            dp[i][j][1]= coins[i][j]+dp[i-1][j][1];
                        }
                        if(dp[i-1][j][2]!=INT_MIN){
                            dp[i][j][2]= coins[i][j]+dp[i-1][j][2];
                        }
                    }
                    else{
                        
                        dp[i][j][0]= coins[i][j]+dp[i-1][j][0];
                        dp[i][j][1]= dp[i-1][j][0];
                        dp[i][j][2]= dp[i-1][j][1];
                        
                        
                        if(dp[i-1][j][1]!=INT_MIN){
                            dp[i][j][1]= max(coins[i][j]+dp[i-1][j][1], 
                            dp[i][j][1]);
                        }

                        if(dp[i-1][j][2]!=INT_MIN){
                            dp[i][j][2]= max(coins[i][j]+dp[i-1][j][2],
                            dp[i][j][2]);
                        }

                    }

                }
                if(j>0){
                    if(coins[i][j]>=0){
                        if(dp[i][j-1][0]!=INT_MIN){
                            dp[i][j][0]= max(coins[i][j]+dp[i][j-1][0]
                            ,dp[i][j][0] );
                        }
                        if(dp[i][j-1][1]!=INT_MIN){
                            dp[i][j][1]= max(coins[i][j]+dp[i][j-1][1],
                            dp[i][j][1]);
                        }
                        if(dp[i][j-1][2]!=INT_MIN){
                            dp[i][j][2]= max(coins[i][j]+dp[i][j-1][2],
                            dp[i][j][2]);
                        }
                    }
                    else{

                        
                        dp[i][j][0]= max(coins[i][j]+dp[i][j-1][0],
                        dp[i][j][0]);
                        dp[i][j][1]= max(dp[i][j-1][0],dp[i][j][1]);
                        dp[i][j][2]= max(dp[i][j-1][1],dp[i][j][2]);
                        
                        
                        if(dp[i][j-1][1]!=INT_MIN){
                            dp[i][j][1]= max(coins[i][j]+dp[i][j-1][1], 
                            dp[i][j][1]);
                        }

                        if(dp[i][j-1][2]!=INT_MIN){
                            dp[i][j][2]= max(coins[i][j]+dp[i][j-1][2],
                            dp[i][j][2]);
                        }

                    }
                    
                }
            }
        }

        return max(max(dp[m-1][n-1][0],dp[m-1][n-1][1]),dp[m-1][n-1][2]);
    } 
};