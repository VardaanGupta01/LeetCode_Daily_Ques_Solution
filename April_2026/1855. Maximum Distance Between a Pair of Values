#include <vector>
#include <algorithm>

class Solution {
public:
    int maxDistance(std::vector<int>& nums1, std::vector<int>& nums2) {
        int i = 0, j = 0, max_dist = 0;
        int n = nums1.size(), m = nums2.size();
        
        while (i < n && j < m) {
          
            if (nums1[i] <= nums2[j]) {
                if (i <= j) {
                    max_dist = std::max(max_dist, j - i);
                }
                j++;
            } 
            
            else {
                i++;
            }
        }
        
        return max_dist;
    }
};