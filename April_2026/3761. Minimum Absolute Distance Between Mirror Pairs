class Solution {
public:
    int find_mirror(int a){
        int temp=0;
        int num;
        while(a){
            temp*=10;
            num= a%10;
            temp+=num;
            a/=10;
        }

        return temp;

    }
    int minMirrorPairDistance(vector<int>& nums) {
        int n= nums.size();
        vector<int>mirror(n-1);
        for(int i=0;i<n-1;i++){
            mirror[i]= find_mirror(nums[i]);
        }
        unordered_map<int,vector<int>>m;
        for(int i=0;i<n;i++){
            m[nums[i]].push_back(i);
        }

        int ans= INT_MAX;
        for(int i=0;i<n-1;i++){
           if(m.count(mirror[i])){
            auto it = upper_bound(m[mirror[i]].begin(),m[mirror[i]].end(),i);
            if(it== m[mirror[i]].end()) continue;
            int idx= *it;
            ans= min(ans, idx-i);
           }
            
        }

        if(ans==INT_MAX) return -1;

        return ans;


        
    }
};