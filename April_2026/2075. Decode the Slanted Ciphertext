class Solution {
public:
    string decodeCiphertext(string encodedText, int rows) {
        int col= encodedText.size()/rows;
        string ans="";
        int startcol=0;
        while(startcol<col){
            int curr_col=startcol;
            int curr_row=0;
            while(true){
                if(curr_col<col && curr_row<rows){
                    ans+=(encodedText[col*curr_row + curr_col]);
                    curr_row++;
                    curr_col++;
                }
                else{
                    break;
                }
            }
            startcol++;

            
        }
        int n= ans.size();
        for(int i=n-1;i>=0;i--){
            if(ans[i]==' '){
                ans.pop_back();
            }
            else break;
        }
        return ans;
        
    }
};