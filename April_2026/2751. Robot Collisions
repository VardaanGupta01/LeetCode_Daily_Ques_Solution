class Solution {
public:
    vector<int> survivedRobotsHealths(vector<int>& positions, vector<int>& healths, string directions) {
        int n = positions.size();
        
        vector<int> ids(n);
        iota(ids.begin(), ids.end(), 0); 
        
        sort(ids.begin(), ids.end(), [&](int id1, int id2){
            return positions[id1] < positions[id2];
        });
        
        stack<int> st; 
        
        for(int id : ids) {
            if(directions[id] == 'R') {
                st.push(id);
            } 
            else {
                while(!st.empty() && healths[id] > 0) {
                    int top_id = st.top();
                    
                    if(healths[top_id] < healths[id]) {
                        healths[top_id] = 0; 
                        healths[id] -= 1;    
                        st.pop();
                    } 
                    else if(healths[top_id] > healths[id]) {
                        healths[top_id] -= 1; 
                        healths[id] = 0;      
                    } 
                    else {
                        healths[top_id] = 0;  
                        healths[id] = 0;
                        st.pop();
                    }
                }
            }
        }
        
        vector<int> ans;
        for(int i = 0; i < n; i++) {
            if(healths[i] > 0) {
                ans.push_back(healths[i]);
            }
        }
        
        return ans;
    }
};